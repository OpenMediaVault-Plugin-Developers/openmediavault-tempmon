msgid "Chart"
msgstr "ແຜນພູມ"

msgid "Create"
msgstr "ສ້າງ"

msgid "Created sensor."
msgstr "ສ້າງເຊັນເຊີແລ້ວ."

msgid "Current"
msgstr "ປັດຈຸບັນ"

msgid "Dashboard widget"
msgstr "ວິດເຈັດໜ້າຄວບຄຸມ"

msgid ""
"Divide raw output by this value to get degrees Celsius. Use 1000 for "
"millidegrees (e.g. thermal_zone), 1 if the script already outputs Celsius."
msgstr ""
"ຫານຄ່າທີ່ໄດ້ຮັບດ້ວຍຄ່ານີ້ເພື່ອໃຫ້ໄດ້ອົງສາເຊວຊຽດ. ໃຊ້ 1000 ສຳລັບມິນລິອົງສາ "
"(ຕົວຢ່າງ: thermal_zone), ຫຼື ໃຊ້ 1 ຖ້າສະຄຣິບສົ່ງຄ່າເປັນອົງສາເຊວຊຽດຢູ່ແລ້ວ."

msgid "Divisor"
msgstr "ຕົວຫານ"

msgid "Docs"
msgstr "ເອກະສານ"

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Group"
msgstr "ກຸ່ມ"

msgid "Include in the performance statistics page."
msgstr "ລວມໄວ້ໃນໜ້າສະຖິຕິປະສິດທິພາບ."

msgid "Label shown on the dashboard widget and performance chart."
msgstr "ປ້າຍຊື່ທີ່ຈະສະແດງໃນວິດເຈັດໜ້າຄວບຄຸມ ແລະ ແຜນພູມປະສິດທິພາບ."

msgid ""
"Must output a raw numeric value. Divide by the divisor below to get degrees "
"Celsius."
msgstr ""
"ຕ້ອງສົ່ງຄ່າອອກມາເປັນຕົວເລກເທົ່ານັ້ນ. "
"ຫານດ້ວຍຕົວຫານຂ້າງລຸ່ມເພື່ອໃຫ້ໄດ້ອົງສາເຊວຊຽດ."

msgid "Name"
msgstr "ຊື່"

msgid "New group name"
msgstr "ຊື່ກຸ່ມໃໝ່"

msgid "None (individual gauge)"
msgstr "ບໍ່ມີ (ແຍກມາດວັດດ່ຽວ)"

msgid "Only letters, numbers, spaces and hyphens are allowed."
msgstr ""
"ອະນຸຍາດໃຫ້ໃຊ້ສະເພາະ ຕົວອັກສອນ, ຕົວເລກ, ຍະຫວ່າງ ແລະ ເຄື່ອງໝາຍຂີດຕໍ່ (-) "
"ເທົ່ານັ້ນ."

msgid ""
"Path where the temperature script will be written. Example - "
"/usr/sbin/cputemp1"
msgstr "ເສັ້ນທາງທີ່ຈະຂຽນສະຄຣິບອຸນຫະພູມໄວ້. ຕົວຢ່າງ - /usr/sbin/cputemp1"

msgid "Performance chart"
msgstr "ແຜນພູມປະສິດທິພາບ"

msgid "Script"
msgstr "ສະຄຣິບ"

msgid "Script path"
msgstr "ເສັ້ນທາງສະຄຣິບ"

msgid ""
"Sensors sharing the same group name are combined into one multi-reading "
"widget and chart. Select an existing group, or leave empty and type a new "
"name below."
msgstr ""
"ເຊັນເຊີທີ່ໃຊ້ຊື່ກຸ່ມດຽວກັນຈະຖືກລວມເຂົ້າເປັນວິດເຈັດ ແລະ ແຜນພູມອັນດຽວກັນ. "
"ເລືອກກຸ່ມທີ່ມີຢູ່ແລ້ວ, ຫຼື ປະຫວ່າງໄວ້ແລ້ວພິມຊື່ໃໝ່ໃສ່ຂ້າງລຸ່ມ."

msgid ""
"Show a gauge widget on the dashboard (ungrouped) or include in the group's "
"combined widget."
msgstr ""
"ສະແດງວິດເຈັດແບບມາດວັດໃນໜ້າຄວບຄຸມ (ແບບບໍ່ລວມກຸ່ມ) ຫຼື "
"ລວມເຂົ້າໃນວິດເຈັດລວມຂອງກຸ່ມ."

msgid "Temp Monitor"
msgstr "ຕິດຕາມອຸນຫະພູມ"

msgid ""
"Type a new group name here to create one. Overrides the selection above. Use"
" letters, numbers, spaces and hyphens only."
msgstr ""
"ພິມຊື່ກຸ່ມໃໝ່ທີ່ນີ້ເພື່ອສ້າງ. ຈະແທນທີ່ການເລືອກຂ້າງເທິງ. ໃຊ້ສະເພາະ ຕົວອັກສອນ,"
" ຕົວເລກ, ຍະຫວ່າງ ແລະ ເຄື່ອງໝາຍຂີດຕໍ່ ເທົ່ານັ້ນ."

msgid "Updated sensor."
msgstr "ອັບເດດເຊັນເຊີແລ້ວ."

msgid "Widget"
msgstr "ວິດເຈັດ"

msgid "omv-extras.org wiki"
msgstr "omv-extras.org wiki"
