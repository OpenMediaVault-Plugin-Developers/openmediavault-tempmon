# Auto-generated by openmediavault-tempmon. Do not edit.
SENSOR_COUNT={{ sensors | length }}
{%- for s in sensors %}
{%- set uuid8 = (s.uuid | replace('-', ''))[:8] %}
SENSOR_{{ loop.index0 }}_UUID="{{ s.uuid }}"
SENSOR_{{ loop.index0 }}_NAME="{{ s.name | replace('"', '\\"') }}"
SENSOR_{{ loop.index0 }}_SCRIPTPATH="{{ s.scriptpath }}"
SENSOR_{{ loop.index0 }}_DIVISOR={{ s.divisor }}
SENSOR_{{ loop.index0 }}_INSTANCE="exec-tempmon-{{ uuid8 }}"
SENSOR_{{ loop.index0 }}_WIDGETGROUP="{{ s.widgetgroup | replace('"', '\\"') }}"
{%- endfor %}
